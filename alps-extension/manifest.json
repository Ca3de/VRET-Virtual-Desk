{
  "manifest_version": 2,
  "name": "ALPS Data Fetcher for Virtual Desk",
  "version": "1.0.0",
  "description": "Fetches ALPS workforce data and auto-fills Virtual Desk Attendance Dashboard",
  "browser_specific_settings": {
    "gecko": {
      "id": "alps-data-fetcher@virtualdesk.local",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "optional": []
      }
    }
  },
  "permissions": [
    "storage",
    "cookies",
    "https://alps-iad.iad.proxy.amazon.com/*",
    "https://iad.alps-basecamp.lamps.amazon.dev/*",
    "*://*/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
